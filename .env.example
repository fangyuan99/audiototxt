# Telegram Bot
ENV_BOT_TOKEN=your_telegram_bot_token
ENV_BOT_SECRET=replace_with_your_bot_password

# Optional Gemini fallback for users who have not set /setkey yet
GOOGLE_API_KEY=
GEMINI_API_KEY=

# Optional Vertex AI JSON fallback
AUTH_MODE=gemini_api_key
VERTEX_SERVICE_ACCOUNT_FILE=
VERTEX_PROJECT=
VERTEX_LOCATION=global

# Optional custom bot state file path
# BOT_STATE_FILE=./data/telegram_bot/state.json
